{
  "fadeUp": {
    "initial": {
      "y": 50,
      "opacity": 0
    },
    "animate": {
      "y": 0,
      "opacity": 1
    },
    "transition": {
      "duration": 0.8,
      "ease": "easeOut",
      "delay": 0.2
    }
  },
  "scaleIn": {
    "initial": {
      "scale": 0.8,
      "opacity": 0
    },
    "animate": {
      "scale": 1,
      "opacity": 1
    },
    "transition": {
      "duration": 0.6,
      "ease": "easeOut"
    }
  },
  "staggeredFadeUp": {
    "initial": {
      "y": 30,
      "opacity": 0
    },
    "animate": {
      "y": 0,
      "opacity": 1
    },
    "transition": {
      "duration": 0.7,
      "ease": "easeOut",
      "staggerChildren": true,
      "delayChildren": 0.1
    }
  }
}